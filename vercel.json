{
  "outputDirectory": "Devpress101/publish/wwwroot",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    },
    {
      "source": "/(.*).gz",
      "headers": [
        { "key": "Content-Encoding", "value": "gzip" }
      ]
    },
    {
      "source": "/(.*).br",
      "headers": [
        { "key": "Content-Encoding", "value": "br" }
      ]
    }
  ]
}