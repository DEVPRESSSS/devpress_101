@page "/contactme"

<section class="min-h-screen bg-white px-8 py-12">
    <div class="max-w-sm mx-auto shadow-sm p-3 rounded-4">

        <!-- Header -->
        <div class="mb-10">
            <p class="text-xs tracking-[0.25em] text-gray-400 uppercase mb-1">Get in touch</p>
            <h1 class="text-4xl font-medium text-gray-900 tracking-tight">Contact</h1>
            <p class="text-sm text-gray-400 mt-1">Feel free to reach out anytime.</p>
            <div class="mt-3 h-0.5 w-10 bg-violet-200 rounded-full"></div>
        </div>

        <!-- Contact Cards -->
        <div class="flex flex-col gap-3">
            @foreach (var contact in Contacts)
            {
                <a href="@contact.Link"
                       class="flex items-center gap-4 px-4 py-3.5 rounded-2xl border border-violet-100 bg-violet-50/30 hover:border-violet-300 hover:bg-violet-50 transition-all duration-150 no-underline">
                    <div class="w-10 h-10 rounded-xl bg-violet-100 flex items-center justify-center shrink-0 text-violet-600">
                        @((MarkupString)contact.Icon)
                    </div>
                    <div>
                        <p class="text-[11px] font-medium tracking-widest text-violet-600 uppercase">@contact.Label</p>
                        <p class="text-sm text-gray-800">@contact.Value</p>
                    </div>
                </a>
            }
        </div>

    </div>
</section>

