@page "/projects"

<section id="projects-section" class="h-auto flex items-center justify-center px-6 mt-2">

    <div class="flex flex-row w-full gap-2" style="min-height: 400px;">

        <!-- Sidebar -->
        <div class="flex-1 border-4 border-white border-t-violet-600 border-r-gray-100 shadow-sm bg-white">

            <!-- Category Pills -->
            <div class="flex flex-row justify-center gap-2 m-2 flex-wrap">
                @foreach (var category in Category)
                {
                    <button @onclick="() => SelectCategory(category)"
                            class="@GetPillClass(category) text-xs font-medium px-3 py-1 rounded-full border-2 cursor-pointer transition-all duration-200">
                        @category.CategoryName
                    </button>
                }
            </div>

            <div class="border border-gray-200 mx-2 mb-2"></div>

            <!-- Year List -->
            <div class="flex flex-col gap-1">
                @foreach (var project in SelectedCategory?.ProjectItems ?? new())
                {
                    <div class="mx-2 mt-1 cursor-pointer rounded transition-all duration-150 @(SelectedProject == project ? "bg-violet-50 border-l-2 border-violet-600" : "hover:bg-gray-50")"
                         @onclick="() => SelectedProject = project">
                        <p class="text-gray-500 text-xs p-2 leading-relaxed">
                            <span class="text-gray-900 font-semibold">@project.Year</span>
                            <span class="text-gray-400"> — @project.Tech</span>
                            <br />
                            <span class="text-violet-600 font-medium">@project.Name</span>
                        </p>
                    </div>
                }
            </div>

        </div>

        <!-- Project Content -->
        <div class="flex-[2] border-4 border-white border-t-violet-600 shadow-sm bg-white p-4 overflow-y-auto">
            @if (SelectedProject is null)
            {
                <div class="h-full flex flex-col items-center justify-center text-center text-gray-300 gap-2 select-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M9 17v-2a4 4 0 014-4h0a4 4 0 014 4v2M7 9a4 4 0 108 0 4 4 0 00-8 0z" />
                    </svg>
                    <p class="text-sm">Select a project to view details</p>
                </div>
            }
            else
            {
                <div class="animate-fade-in">
                    <!-- Header -->
                    <div class="flex items-start justify-between mb-3">
                        <div>
                            <h2 class="text-lg font-bold text-gray-900">@SelectedProject.Name</h2>
                            <span class="inline-block text-xs font-medium text-violet-600 bg-violet-50 px-2 py-0.5 rounded mt-1">
                                @SelectedProject.Year
                            </span>
                            <span class="inline-block text-xs font-medium text-violet-600 bg-violet-50 px-2 py-0.5 rounded mt-1">
                                @SelectedProject.Role
                            </span>
                        </div>
                        <span class="text-xs text-gray-400 bg-gray-100 px-2 py-1 rounded">@SelectedProject.Tech</span>
                    </div>

                    <div class="border-t border-gray-100 my-3"></div>

                    <!-- Description -->
                    <p class="text-sm text-gray-600 leading-relaxed mb-4">@SelectedProject.Description</p>

                    <div class="border-t border-gray-100 my-3"></div>

                    <!-- TechStack -->
                    <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">TechStack used during development</h4>
                    <div class="flex flex-wrap items-start justify-start mb-3 gap-1">
                        @foreach (var item in SelectedProject.TechStack)
                        {
                            <span class="inline-block text-xs font-medium text-gray-400 bg-violet-50 px-2 py-0.5 rounded mt-1">
                                @item
                            </span>
                        }
                    </div>

                    <div class="border-t border-gray-100 my-3"></div>

                    <!-- Features -->
                    <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Key Features</h4>
                    <ul class="flex flex-col gap-1">
                        @foreach (var feature in SelectedProject.Features)
                        {
                            <li class="flex items-start gap-2 text-sm text-gray-600">
                                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-violet-500 flex-shrink-0"></span>
                                @feature
                            </li>
                        }
                    </ul>

                    <!-- Screenshots -->
                    @if (SelectedProject.SystemSS?.Count > 0)
                    {
                        <div class="border-t border-gray-100 my-3"></div>

                        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Screenshots</h4>

                        <div class="flex flex-col gap-4">
                            @foreach (var ss in SelectedProject.SystemSS)
                            {
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-gray-400 font-medium">@ss.Title</span>
                                    <img src="@ss.ImagePath"
                                         alt="@ss.Title"
                                         class="w-full h-auto rounded-lg border border-gray-100 shadow-sm object-contain" />
                                </div>
                            }
                        </div>
                    }

                </div>
            }
        </div>

    </div>

</section>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
        animation: fadeIn 0.2s ease-out both;
    }
</style>

@code {
    private ProjectItem? SelectedProject;
    private CategoryOfProjects? SelectedCategory;

    protected override void OnInitialized()
    {
        SelectedCategory = Category.FirstOrDefault();
        SelectedProject  = SelectedCategory?.ProjectItems?.FirstOrDefault();
    }

    private void SelectCategory(CategoryOfProjects category)
    {
        SelectedCategory = category;
        SelectedProject  = category.ProjectItems?.FirstOrDefault();
    }

    private string GetPillClass(CategoryOfProjects category)
    {
        return SelectedCategory == category
            ? "bg-violet-600 text-white border-violet-600 hover:bg-violet-700 hover:border-violet-700"
            : "bg-white text-violet-600 border-violet-600 hover:bg-violet-50";
    }

    private List<CategoryOfProjects> Category = new()
    {
        new CategoryOfProjects
        {
            CategoryName = "Academic Year",
            ProjectItems = new List<ProjectItem>
            {
                new ProjectItem
                {
                    Year        = "1st Year",
                    Tech        = "C# · WPF",
                    Name        = "Gym Management System",
                    Description = "A desktop application built with C# and Windows Presentation Foundation (WPF) for managing gym memberships, attendance tracking, and billing. Designed with a clean MVVM architecture to keep the UI and business logic separate.",
                    Role        = "Leader",
                    Features = new()
                    {
                        "Member registration and profile management",
                        "Attendance logging using QRcode",
                        "Subscription and payment tracking",
                        "Admin dashboard with membership statistics",
                    },
                    TechStack = new() { "C# - BackEnd", "MSSQL - Database","WPF(Template)","Figma(UI prototype)" },
                    SystemSS = new()
                    {
                        new ImageUrl { Title = "Login Form",         ImagePath = "/assets/Login.png" },
                        new ImageUrl { Title = "Forgot Password Form", ImagePath = "/assets/ForgotPassword.png" },
                        new ImageUrl { Title = "Admin Dashboard",    ImagePath = "/assets/AdminDashboard.png" },
                        new ImageUrl { Title = "Client Management",  ImagePath = "/assets/ClientList.png" },
                        new ImageUrl { Title = "Coach Management",   ImagePath = "/assets/CoachList.png" },
                        new ImageUrl { Title = "Scan QR",            ImagePath = "/assets/ScanQR.png" },
                        new ImageUrl { Title = "Payment",            ImagePath = "/assets/Payment.png" },
                    }
