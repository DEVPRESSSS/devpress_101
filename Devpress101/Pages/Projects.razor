                    Description = "A web application built with Django for managing property rentals — handling tenant records, lease agreements, and monthly payment tracking through a clean admin-facing interface.",
                    Role        = "Leader",
                    Features = new()
                    {
                        "Tenant and unit management",
                        "Lease contract generation",
                        "Monthly billing and payment history",
                        "Automated due date reminders",
                        "2D mapping",
                    },
                    TechStack = new() { "Python", "MySQL" }
                },
                new ProjectItem
                {
                    Year        = "4th Year",
                    Tech        = "Go · Gin",
                    Name        = "Hotel Management System",
                    Description = "A full-stack web application written in Go using the Gin framework. Handles hotel room reservations, guest check-ins/outs, and billing with a RESTful API backend and a responsive frontend.",
                    Role        = "Solo",
